# --- Storage paths ---
# Where memories.json, embeddings.db, weread_state.json live.
# Default if unset: ~/.mcp-memory (i.e. user's home directory).
MCP_MEMORY_DIR=~/.mcp-memory

# Where the weread module lives (containing weread_fetch.py / weread_write.py).
# Default if unset: ./weread relative to cognition_server.py.
WEREAD_MODULE_DIR=./weread

# Optional explicit overrides for derived paths (rarely needed).
# WEREAD_STATE_PATH=${MCP_MEMORY_DIR}/weread_state.json
# WEREAD_URL_MAP_PATH=${MCP_MEMORY_DIR}/weread_url_map.json

# --- Ports ---
# Full cognition server (admin / power user)
COGNITION_PORT=8769

# Lite server (the one your AI persona connects to)
COGNITION_LITE_PORT=8775

# --- Reading: feature toggles (informational; actual gating is in cognition_lite_server.py) ---
# Keep weread tools registered
ENABLE_WEREAD=1
# Keep jjwxc tools registered
ENABLE_JJWXC=1

# --- Behavior tuning ---
# Pairwise cosine threshold for HippoRAG synonym-edge construction
SYNONYM_EDGE_THRESHOLD=0.75

# Paper trail: max archived versions per key (oldest auto-pruned)
PAPER_TRAIL_MAX_VERSIONS=5

# Paper trail: only archive when diff in characters >= this
PAPER_TRAIL_MIN_DIFF_CHARS=20
